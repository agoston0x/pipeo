# ── pipeo server config ──────────────────────────────────────────────────

# Hono REST API port
PORT=4070

# Bee node URL (must be reachable from this process)
SWARM_URL=http://swarm:1633

# GSOC topic name. Same value clients use when sending. Identifier becomes pipe.<name>.
GSOC_CHANNEL_NAME=pipeo-mainnet

# Postage batch id used for GSOC mining (the aggregator owner). Buy via Bee API
# or let the server auto-buy on first start (NOT in MVP).
POSTAGE_BATCH_ID=

# Owner overlay address — your Bee node's overlay. Leave empty to auto-detect on boot
# from `bee.getNodeAddresses()`. Set explicitly only if you want to lock to a specific value.
BEE_OVERLAY_ADDRESS=

# Alchemy mainnet for ENS lookups. Sign up at alchemy.com → create app
# (Ethereum Mainnet) → copy HTTPS URL. Free tier handles 300M req/mo.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/REPLACE_WITH_ALCHEMY_KEY
# Fallback (no key, public): https://ethereum-rpc.publicnode.com

# Suffix that all valid ENS names must end with (defense against typo squatting in MVP).
# E.g. ".pipeo.eth" — leave empty to accept any ENS.
ENS_SUFFIX=.pipeo.eth

# Where SQLite lives. Path inside container.
DATA_DIR=/var/lib/pipeo
