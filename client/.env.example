# ── pipeo client config ──────────────────────────────────────────────────

# HTTP port the client exposes (Openclaw or any HTTP client POSTs here)
PORT=4071

# Local Bee node (the one this container runs alongside)
SWARM_URL=http://swarm:1633

# Postage batch id on the local Bee. Buy one with:
#   curl -X POST http://localhost:1633/stamps/100000000/22
POSTAGE_BATCH_ID=

# ── Shared with the Hetzner server ──────────────────────────────────────────
# Same value the aggregator uses for its GSOC topic. The server prints/owns
# the GSOC signer private key — copy it here so this client publishes to the
# same chunk address the server subscribes to.
GSOC_CHANNEL_NAME=pipeo-mainnet
GSOC_SIGNER_PRIVATE_KEY=

# ── This agent's identity (must match an ENS name on Ethereum mainnet) ──────
AGENT_ENS_NAME=alice.pipeo.eth
AGENT_PRIVATE_KEY=
