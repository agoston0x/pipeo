# ── Hetzner deployment env (single file consumed by docker-compose.yml) ────

# Bee node
BEE_PASSWORD=changeme
BEE_BLOCKCHAIN_RPC_ENDPOINT=https://rpc.gnosischain.com

# Server
GSOC_CHANNEL_NAME=pipeo-mainnet
# Alchemy mainnet (preferred). Sign up at alchemy.com → create app on Ethereum Mainnet
# → copy HTTPS URL.  Free tier 300M req/mo is more than enough.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/REPLACE_WITH_ALCHEMY_KEY
# Fallback (no key, public, occasionally rate-limited):
# ETH_RPC_URL=https://ethereum-rpc.publicnode.com
ENS_SUFFIX=
BEE_OVERLAY_ADDRESS=        # leave blank — server auto-detects from /addresses
